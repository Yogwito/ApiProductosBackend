{
  "info": {
    "_postman_id": "2f3db6ad-6df0-4b91-b499-4e5ec3db8200",
    "name": "ApiProductos",
    "description": "Coleccion para probar la API REST de ApiProductos con JWT Auth, login en dos pasos y correos.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000/api"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "verificationCode",
      "value": ""
    },
    {
      "key": "productoId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@api.com\",\n  \"password\": \"password\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "login"
              ]
            },
            "description": "Valida credenciales, genera un codigo de 6 digitos y lo envia por correo."
          }
        },
        {
          "name": "Verify Code",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@api.com\",\n  \"code\": \"{{verificationCode}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/verify-code",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "verify-code"
              ]
            },
            "description": "Verifica el codigo enviado por correo y emite el JWT."
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "me"
              ]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "logout"
              ]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/refresh-token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "refresh-token"
              ]
            },
            "description": "Ruta principal para renovar el JWT de 5 minutos."
          }
        },
        {
          "name": "Refresh Legacy",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "refresh"
              ]
            },
            "description": "Ruta mantenida por compatibilidad."
          }
        }
      ]
    },
    {
      "name": "Productos",
      "item": [
        {
          "name": "Index",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/productos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "productos"
              ]
            }
          }
        },
        {
          "name": "Show",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/productos/{{productoId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "productos",
                "{{productoId}}"
              ]
            }
          }
        },
        {
          "name": "Store",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Arroz\",\n  \"precio\": 5.75,\n  \"stock\": 40,\n  \"descripcion\": \"Arroz blanco x 1kg\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/productos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "productos"
              ]
            },
            "description": "Crea el producto y envia un correo al usuario autenticado o al destinatario configurado."
          }
        },
        {
          "name": "Update",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"precio\": 6.10,\n  \"stock\": 35,\n  \"descripcion\": \"Arroz actualizado\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/productos/{{productoId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "productos",
                "{{productoId}}"
              ]
            }
          }
        },
        {
          "name": "Destroy",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/productos/{{productoId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "productos",
                "{{productoId}}"
              ]
            }
          }
        }
      ]
    }
  ]
}
