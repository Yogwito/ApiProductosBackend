              "body": "{\n  \"message\": \"Login Correcto\",\n  \"token\": \"jwt_token\",\n  \"user\": {\n    \"id\": 1,\n    \"name\": \"Administrador\",\n    \"email\": \"admin@api.com\",\n    \"role\": \"admin\"\n  }\n}"
